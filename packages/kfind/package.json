{
  "name": "@kfind/kfind",
  "version": "1.0.0-rc.2",
  "description": "Korean lemma and inflection matching for JavaScript",
  "license": "SEE LICENSE IN LICENSES.md",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeokminHong/kfind.git",
    "directory": "packages/kfind"
  },
  "homepage": "https://github.com/SeokminHong/kfind#readme",
  "keywords": [
    "korean",
    "morphology",
    "search",
    "wasm",
    "webassembly"
  ],
  "files": [
    "bin",
    "generated",
    "node",
    "assets",
    "assets.d.ts",
    "assets.js",
    "LICENSE",
    "LICENSES.md",
    "README.md"
  ],
  "bin": {
    "kfind": "bin/kfind.js"
  },
  "main": "./node/kfind.js",
  "module": "./generated/kfind.js",
  "types": "./generated/kfind.d.ts",
  "exports": {
    ".": {
      "types": "./generated/kfind.d.ts",
      "browser": "./generated/kfind.js",
      "node": "./node/kfind.js",
      "import": "./generated/kfind.js",
      "default": "./generated/kfind.js"
    },
    "./assets": {
      "types": "./assets.d.ts",
      "import": "./assets.js",
      "default": "./assets.js"
    },
    "./assets/morphology-component-compact.kfc": "./assets/morphology-component-compact.kfc",
    "./assets/predicates.enriched.tsv": "./assets/predicates.enriched.tsv"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "benchmark:startup": "../../scripts/benchmark-npm-startup.sh",
    "build": "../../scripts/build-npm-package.sh",
    "test": "../../scripts/test-npm-package.sh",
    "pack:check": "../../scripts/check-npm-package.sh",
    "prepack": "../../scripts/test-npm-package.sh"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@10.33.0"
}
