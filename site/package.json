{
  "name": "kfind-site",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "prepare:assets": "./scripts/prepare-assets.sh",
    "upload:component": "./scripts/upload-component-resource.sh",
    "types": "wrangler types worker-configuration.d.ts --env-interface CloudflareBindings --include-runtime=false",
    "types:check": "wrangler types worker-configuration.d.ts --env-interface CloudflareBindings --include-runtime=false --check",
    "dev": "pnpm run prepare:assets && vite",
    "dev:pages": "pnpm run build && wrangler pages dev",
    "build": "pnpm run prepare:assets && tsc --noEmit && tsc --noEmit --project functions/tsconfig.json && vite build",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "deploy": "pnpm run upload:component && pnpm run build && wrangler pages deploy dist --project-name kfind --branch main"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260713.1",
    "@seokminhong/configs": "3.1.0",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@vanilla-extract/css": "1.21.1",
    "@vanilla-extract/vite-plugin": "5.2.4",
    "eslint": "9.39.5",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "wrangler": "4.110.0"
  },
  "packageManager": "pnpm@10.33.0",
  "prettier": "@seokminhong/configs/prettier"
}
