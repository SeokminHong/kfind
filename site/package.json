{
  "name": "kfind-site",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "prepare:assets": "./scripts/prepare-assets.sh",
    "dev": "pnpm run prepare:assets && vite",
    "build": "pnpm run prepare:assets && tsc --noEmit && vite build",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "deploy": "pnpm run build && pnpm dlx wrangler pages deploy dist --project-name kfind --branch main"
  },
  "devDependencies": {
    "@seokminhong/configs": "3.1.0",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@vanilla-extract/css": "1.21.1",
    "@vanilla-extract/vite-plugin": "5.2.4",
    "eslint": "9.39.5",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "vite": "8.1.4"
  },
  "packageManager": "pnpm@10.33.0",
  "prettier": "@seokminhong/configs/prettier"
}
