{
  "name": "kfind-site",
  "private": true,
  "version": "0.3.0-rc.3",
  "type": "module",
  "scripts": {
    "prepare:assets": "./scripts/prepare-assets.sh",
    "upload:component": "./scripts/upload-component-resource.sh",
    "types": "wrangler types worker-configuration.d.ts --env-interface CloudflareBindings --include-runtime=false",
    "types:check": "wrangler types worker-configuration.d.ts --env-interface CloudflareBindings --include-runtime=false --check",
    "typegen": "react-router typegen",
    "dev": "pnpm run prepare:assets && react-router dev",
    "dev:pages": "pnpm run build && wrangler pages dev build/client",
    "build": "pnpm run prepare:assets && react-router typegen && tsc --noEmit && tsc --noEmit --project functions/tsconfig.json && react-router build",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "wrangler pages dev build/client",
    "deploy": "pnpm run upload:component && pnpm run build && wrangler pages deploy build/client --project-name kfind --branch main"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260713.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@react-router/dev": "8.2.0",
    "@seokminhong/configs": "3.1.0",
    "@types/d3": "7.4.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vanilla-extract/css": "1.21.1",
    "@vanilla-extract/vite-plugin": "5.2.4",
    "eslint": "9.39.5",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "wrangler": "4.110.0"
  },
  "packageManager": "pnpm@10.33.0",
  "prettier": "@seokminhong/configs/prettier",
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@codemirror/commands": "6.10.4",
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "d3": "7.9.0",
    "i18next": "26.3.6",
    "i18next-browser-languagedetector": "8.2.1",
    "isbot": "5.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.10",
    "react-router": "8.2.0"
  }
}
