{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "kfind",
  "pages_build_output_dir": "./dist",
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_compat"],
  "r2_buckets": [
    {
      "binding": "KFIND_ASSETS",
      "bucket_name": "kfind-assets",
    },
  ],
}
